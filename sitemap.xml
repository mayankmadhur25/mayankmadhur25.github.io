---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ "/" | absolute_url }}</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  {% comment %} Section / topic / tool pages (any page with front matter, minus the ones we skip) {% endcomment %}
  {% assign pages = site.html_pages | where_exp: "p", "p.sitemap != false" %}
  {% for p in pages %}{% unless p.url == "/" or p.url contains "404" or p.url contains "index.html" %}
  <url>
    <loc>{{ p.url | absolute_url }}</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endunless %}{% endfor %}
  {% comment %} static pages with no front matter (invisible to the loop above) — remove a line here if you ever give that page front matter {% endcomment %}
  <url>
    <loc>{{ "/about.html" | absolute_url }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>{{ "/podcast.html" | absolute_url }}</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {% comment %} Every edition, via its card. Uses external_link (the real /edition-N.html) when present, else the post URL. {% endcomment %}
  {% for post in site.posts %}
  <url>
    <loc>{% if post.external_link %}{{ post.external_link | absolute_url }}{% else %}{{ post.url | absolute_url }}{% endif %}</loc>
    <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  {% endfor %}
</urlset>
