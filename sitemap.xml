---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.url }}/</loc></url>
  <url><loc>{{ site.url }}/about.html</loc></url>
  <url><loc>{{ site.url }}/podcast.html</loc></url>
  <url><loc>{{ site.url }}/archive/</loc></url>
  <url><loc>{{ site.url }}/perspectives/</loc></url>
  <url><loc>{{ site.url }}/ask/</loc></url>
  <url><loc>{{ site.url }}/research/</loc></url>
  <url><loc>{{ site.url }}/index-tool/</loc></url>
  <url><loc>{{ site.url }}/tools/health-stack/</loc></url>
  {% assign cats = "policy,strategy,digital-health,pharma,biotech,geopolitics,governance" | split: "," %}
  {% for c in cats %}<url><loc>{{ site.url }}/topics/{{ c }}/</loc></url>
  {% endfor %}
  {% for post in site.posts %}
  <url>
    <loc>{% if post.external_link %}{{ site.url }}{{ post.external_link }}{% else %}{{ site.url }}{{ post.url }}{% endif %}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
</urlset>
